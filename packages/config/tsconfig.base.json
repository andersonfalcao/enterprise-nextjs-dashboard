{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "es2022"],
    "strict": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@ui/*": ["../ui/src/*"],
      "@logger": ["../logger/src/index.ts"]
    }
  }
}
